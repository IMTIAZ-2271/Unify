<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.calendarapp.controller.RegisterController"
      styleClass="login-root" prefWidth="900" prefHeight="620">

    <VBox styleClass="brand-panel" alignment="CENTER" prefWidth="360" spacing="12">
        <Label text="📅" style="-fx-font-size:64;"/>
        <Label text="CalendarApp" style="-fx-font-size:30;-fx-font-weight:bold;-fx-text-fill:white;"/>
        <Label text="Join and start organizing your life." wrapText="true"
               style="-fx-font-size:14;-fx-text-fill:rgba(255,255,255,0.8);-fx-text-alignment:center;"/>
    </VBox>

    <ScrollPane fitToWidth="true" HBox.hgrow="ALWAYS" style="-fx-background:white;-fx-background-color:white;">
        <VBox styleClass="form-panel" alignment="CENTER" spacing="0">
            <VBox maxWidth="360" spacing="14">
                <Label text="Create Account" style="-fx-font-size:24;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>

                <VBox spacing="5">
                    <Label text="Username *" styleClass="field-label"/>
                    <TextField fx:id="usernameField" promptText="3-50 chars, letters/numbers/_" styleClass="input"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="Email *" styleClass="field-label"/>
                    <TextField fx:id="emailField" promptText="you@example.com" styleClass="input"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="Display Name" styleClass="field-label"/>
                    <TextField fx:id="displayNameField" promptText="Your full name (optional)" styleClass="input"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="Password *" styleClass="field-label"/>
                    <PasswordField fx:id="passwordField" promptText="min 6 characters" styleClass="input"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="Confirm Password *" styleClass="field-label"/>
                    <PasswordField fx:id="confirmField" promptText="repeat password" styleClass="input"/>
                </VBox>

                <Label fx:id="errorLabel" styleClass="err" wrapText="true" maxWidth="360"/>

                <Button fx:id="registerBtn" text="Create Account" styleClass="btn-primary"
                        maxWidth="Infinity" prefHeight="42" onAction="#doRegister"/>

                <HBox alignment="CENTER" spacing="8">
                    <Label text="Have an account?" style="-fx-text-fill:#888;"/>
                    <Button text="Sign In" styleClass="btn-link" onAction="#goLogin"/>
                </HBox>
            </VBox>
        </VBox>
    </ScrollPane>
</HBox>
