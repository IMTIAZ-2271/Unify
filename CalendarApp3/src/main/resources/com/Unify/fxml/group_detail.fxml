<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="640" prefWidth="800" style="-fx-background-color:white;" xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17.0.12" fx:controller="com.Unify.controller.GroupDetailController">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="16"
          style="-fx-padding:20 24;-fx-border-color:#E2E8F0;-fx-border-width:0 0 1 0;-fx-background-color:white;">
        <StackPane>
            <ImageView fx:id="groupAvatar" fitHeight="80" fitWidth="80"/>
        </StackPane>
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label fx:id="groupName" style="-fx-font-size:22;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
            <Label fx:id="groupCode" style="-fx-text-fill:#888;-fx-font-size:11;"/>
            <HBox spacing="12">
                <Label fx:id="memberCount" style="-fx-text-fill:#64748B;-fx-font-size:12;"/>
                <Label fx:id="parentLabel" style="-fx-text-fill:#94A3B8;-fx-font-size:12;"/>
            </HBox>
            <Label fx:id="roleLabel" style="-fx-text-fill:#3B82F6;-fx-font-weight:bold;-fx-font-size:12;"/>
        </VBox>
        <VBox alignment="TOP_RIGHT" spacing="5.0">
            <HBox fx:id="adminBar" spacing="8">
                <Button onAction="#doEditGroup" styleClass="btn-outline-sm" text="✏️ Edit Group"/>
            </HBox>
            <Button fx:id="leaveBtn" onAction="#doLeave" styleClass="btn-danger-sm" text="Leave Group"/>
            <Button fx:id="joinBtn" onAction="#requestJoin" text="Join Group"/>
        </VBox>
    </HBox>
    <Label fx:id="descLabel" style="-fx-padding:8 16;-fx-text-fill:#64748B;" wrapText="true"/>

    <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">

        <!-- Members tab -->
        <Tab text="👥 Members">
            <VBox spacing="0">
                <HBox alignment="CENTER" spacing="8" style="-fx-padding:8 12;">
                    <TextField fx:id="userSearchField" onAction="#doSearchUser" promptText="Search users to invite…"
                               HBox.hgrow="ALWAYS"/>
                    <Button onAction="#doSearchUser" styleClass="btn-primary-sm" text="Search"/>
                </HBox>
                <ScrollPane fitToWidth="true" prefHeight="90"
                            style="-fx-background:#F8FAFC;-fx-background-color:#F8FAFC;">
                    <VBox fx:id="userSearchResults" spacing="2" style="-fx-padding:4;"/>
                </ScrollPane>
                <Separator/>
                <ScrollPane fitToWidth="true" style="-fx-background:white;-fx-background-color:white;"
                            VBox.vgrow="ALWAYS">
                    <VBox fx:id="membersList" spacing="0"/>
                </ScrollPane>
            </VBox>
        </Tab>

        <!-- Group Calendar tab -->
        <Tab text="📅 Calendar">
            <VBox fx:id="groupCalendarContainer" spacing="0" style="-fx-background-color:white;" VBox.vgrow="ALWAYS"/>
        </Tab>

        <!-- Events list tab -->
        <Tab text="📋 Events">
            <ScrollPane fitToWidth="true" style="-fx-background:white;-fx-background-color:white;" VBox.vgrow="ALWAYS">
                <VBox fx:id="eventsList" spacing="6" style="-fx-padding:8;"/>
            </ScrollPane>
        </Tab>

        <!-- Sub-groups tab -->
        <Tab text="🔗 Sub-Groups">
            <ScrollPane fitToWidth="true" style="-fx-background:white;-fx-background-color:white;">
                <VBox fx:id="subGroupsList" spacing="8" style="-fx-padding:12;"/>
            </ScrollPane>
        </Tab>
    </TabPane>
</VBox>
