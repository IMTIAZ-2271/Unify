<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="680" prefWidth="780" style="-fx-background-color:white;" xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.Unify.controller.DayViewController">

    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="cal-header">
        <Button mnemonicParsing="false" onAction="#gotoMonthView" styleClass="back-btn" text="← Back"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button mnemonicParsing="false" onAction="#gotoPreviousDay" text="◀"/>
        <Label fx:id="dateLabel" alignment="CENTER" contentDisplay="CENTER" prefWidth="280.0" styleClass="month-label"
               textAlignment="CENTER"/>
        <Button mnemonicParsing="false" onAction="#gotoNextDay" text="▶"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button onAction="#newEvent" styleClass="btn-primary-sm" text="＋ New Event"/>
    </HBox>

    <ScrollPane fx:id="scrollPane" fitToWidth="true" style="-fx-background:white;-fx-background-color:white;"
                VBox.vgrow="ALWAYS">
        <AnchorPane fx:id="timePane" prefWidth="730" style="-fx-background-color:white;"/>
    </ScrollPane>
</VBox>
