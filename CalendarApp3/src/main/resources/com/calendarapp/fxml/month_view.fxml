<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox style="-fx-background-color:white;" VBox.vgrow="ALWAYS" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.calendarapp.controller.MonthViewController">
   <VBox>
      <children>
         <Button fx:id="selectAllButton" mnemonicParsing="false" onAction="#checkOrUncheckAll" prefHeight="26.0" prefWidth="81.0" text="Select All" />

          <!-- Left: Group filter panel -->
          <VBox fx:id="filterPanel" prefWidth="175" spacing="4" styleClass="filter-panel">
        <!-- populated programmatically -->
    </VBox>
      </children>
   </VBox>

    <Separator orientation="VERTICAL" style="-fx-opacity:0.3;" />

    <!-- Right: Calendar -->
    <VBox fx:id="calendarArea" spacing="0" HBox.hgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="cal-header">
            <Region HBox.hgrow="ALWAYS" />
         <HBox alignment="CENTER" spacing="10.0">
            <children>
                  <Button onAction="#prevMonth" styleClass="nav-btn" text="◀" />
                  <Label fx:id="monthYearLabel" alignment="CENTER" contentDisplay="CENTER" prefWidth="150.0" styleClass="month-label" textAlignment="CENTER" />
                  <Button onAction="#nextMonth" styleClass="nav-btn" text="▶" />
            </children>
         </HBox>
            <Button onAction="#goToday" styleClass="btn-outline-sm" text="Today" />
         <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#newEvent" styleClass="btn-primary-sm" text="＋ New Event" />
        </HBox>

        <!-- Day-of-week header -->
        <GridPane styleClass="dow-row">
            <Label styleClass="dow" text="Sun" GridPane.columnIndex="0" />
            <Label styleClass="dow" text="Mon" GridPane.columnIndex="1" />
            <Label styleClass="dow" text="Tue" GridPane.columnIndex="2" />
            <Label styleClass="dow" text="Wed" GridPane.columnIndex="3" />
            <Label styleClass="dow" text="Thu" GridPane.columnIndex="4" />
            <Label styleClass="dow" text="Fri" GridPane.columnIndex="5" />
            <Label styleClass="dow" text="Sat" GridPane.columnIndex="6" />
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="14.286" />
                <ColumnConstraints hgrow="ALWAYS" percentWidth="14.286" />
                <ColumnConstraints hgrow="ALWAYS" percentWidth="14.286" />
                <ColumnConstraints hgrow="ALWAYS" percentWidth="14.286" />
                <ColumnConstraints hgrow="ALWAYS" percentWidth="14.286" />
                <ColumnConstraints hgrow="ALWAYS" percentWidth="14.286" />
                <ColumnConstraints hgrow="ALWAYS" percentWidth="14.286" />
            </columnConstraints>
         <rowConstraints>
            <RowConstraints />
         </rowConstraints>
        </GridPane>

        <ScrollPane fitToWidth="true" style="-fx-background:white;-fx-background-color:white;" VBox.vgrow="ALWAYS">
            <GridPane fx:id="calGrid" style="-fx-background-color:white;">
                <columnConstraints>
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="14.286" />
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="14.286" />
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="14.286" />
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="14.286" />
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="14.286" />
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="14.286" />
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="14.286" />
                </columnConstraints>
            </GridPane>
        </ScrollPane>
    </VBox>
</HBox>
