<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.calendarapp.controller.MonthViewController"
      style="-fx-background-color:white;" VBox.vgrow="ALWAYS">

    <!-- Left: Group filter panel -->
    <VBox fx:id="filterPanel" styleClass="filter-panel" prefWidth="175" spacing="4">
        <!-- populated programmatically -->
    </VBox>

    <Separator orientation="VERTICAL" style="-fx-opacity:0.3;"/>

    <!-- Right: Calendar -->
    <VBox HBox.hgrow="ALWAYS" spacing="0">
        <HBox styleClass="cal-header" alignment="CENTER_LEFT" spacing="10">
            <Button text="◀" styleClass="nav-btn" onAction="#prevMonth"/>
            <Label fx:id="monthYearLabel" styleClass="month-label"/>
            <Button text="▶" styleClass="nav-btn" onAction="#nextMonth"/>
            <Button text="Today" styleClass="btn-outline-sm" onAction="#goToday"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="＋ New Event" styleClass="btn-primary-sm" onAction="#newEvent"/>
        </HBox>

        <!-- Day-of-week header -->
        <GridPane styleClass="dow-row">
            <Label text="Sun" styleClass="dow" GridPane.columnIndex="0"/>
            <Label text="Mon" styleClass="dow" GridPane.columnIndex="1"/>
            <Label text="Tue" styleClass="dow" GridPane.columnIndex="2"/>
            <Label text="Wed" styleClass="dow" GridPane.columnIndex="3"/>
            <Label text="Thu" styleClass="dow" GridPane.columnIndex="4"/>
            <Label text="Fri" styleClass="dow" GridPane.columnIndex="5"/>
            <Label text="Sat" styleClass="dow" GridPane.columnIndex="6"/>
            <columnConstraints>
                <ColumnConstraints percentWidth="14.286" hgrow="ALWAYS"/>
                <ColumnConstraints percentWidth="14.286" hgrow="ALWAYS"/>
                <ColumnConstraints percentWidth="14.286" hgrow="ALWAYS"/>
                <ColumnConstraints percentWidth="14.286" hgrow="ALWAYS"/>
                <ColumnConstraints percentWidth="14.286" hgrow="ALWAYS"/>
                <ColumnConstraints percentWidth="14.286" hgrow="ALWAYS"/>
                <ColumnConstraints percentWidth="14.286" hgrow="ALWAYS"/>
            </columnConstraints>
        </GridPane>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background:white;-fx-background-color:white;">
            <GridPane fx:id="calGrid" style="-fx-background-color:white;">
                <columnConstraints>
                    <ColumnConstraints percentWidth="14.286" hgrow="ALWAYS"/>
                    <ColumnConstraints percentWidth="14.286" hgrow="ALWAYS"/>
                    <ColumnConstraints percentWidth="14.286" hgrow="ALWAYS"/>
                    <ColumnConstraints percentWidth="14.286" hgrow="ALWAYS"/>
                    <ColumnConstraints percentWidth="14.286" hgrow="ALWAYS"/>
                    <ColumnConstraints percentWidth="14.286" hgrow="ALWAYS"/>
                    <ColumnConstraints percentWidth="14.286" hgrow="ALWAYS"/>
                </columnConstraints>
            </GridPane>
        </ScrollPane>
    </VBox>
</HBox>
