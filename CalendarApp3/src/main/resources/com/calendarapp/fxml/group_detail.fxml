<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.calendarapp.controller.GroupDetailController"
      style="-fx-background-color:white;" prefWidth="800" prefHeight="640">

    <!-- Header -->
    <HBox style="-fx-padding:20 24;-fx-border-color:#E2E8F0;-fx-border-width:0 0 1 0;-fx-background-color:white;"
          spacing="16" alignment="CENTER_LEFT">
        <StackPane><ImageView fx:id="groupAvatar" fitWidth="80" fitHeight="80"/></StackPane>
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label fx:id="groupName"   style="-fx-font-size:22;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
            <Label fx:id="groupCode"   style="-fx-text-fill:#888;-fx-font-size:11;"/>
            <HBox spacing="12">
                <Label fx:id="memberCount" style="-fx-text-fill:#64748B;-fx-font-size:12;"/>
                <Label fx:id="parentLabel" style="-fx-text-fill:#94A3B8;-fx-font-size:12;"/>
            </HBox>
            <Label fx:id="roleLabel"   style="-fx-text-fill:#3B82F6;-fx-font-weight:bold;-fx-font-size:12;"/>
        </VBox>
        <VBox spacing="8" alignment="TOP_RIGHT">
            <HBox fx:id="adminBar" spacing="8">
                <Button text="✏️ Edit Group" styleClass="btn-outline-sm" onAction="#doEditGroup"/>
            </HBox>
            <Button text="Leave Group" styleClass="btn-danger-sm" onAction="#doLeave"/>
        </VBox>
    </HBox>
    <Label fx:id="descLabel" wrapText="true" style="-fx-padding:8 16;-fx-text-fill:#64748B;"/>

    <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">

        <!-- Members tab -->
        <Tab text="👥 Members">
            <VBox spacing="0">
                <HBox style="-fx-padding:8 12;" spacing="8" alignment="CENTER">
                    <TextField fx:id="userSearchField" promptText="Search users to invite…"
                               HBox.hgrow="ALWAYS" onAction="#doSearchUser"/>
                    <Button text="Search" styleClass="btn-primary-sm" onAction="#doSearchUser"/>
                </HBox>
                <ScrollPane fitToWidth="true" prefHeight="90"
                            style="-fx-background:#F8FAFC;-fx-background-color:#F8FAFC;">
                    <VBox fx:id="userSearchResults" spacing="2" style="-fx-padding:4;"/>
                </ScrollPane>
                <Separator/>
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background:white;-fx-background-color:white;">
                    <VBox fx:id="membersList" spacing="0"/>
                </ScrollPane>
            </VBox>
        </Tab>

        <!-- Group Calendar tab -->
        <Tab text="📅 Calendar">
            <VBox fx:id="groupCalendarContainer" VBox.vgrow="ALWAYS" spacing="0"
                  style="-fx-background-color:white;"/>
        </Tab>

        <!-- Events list tab -->
        <Tab text="📋 Events">
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background:white;-fx-background-color:white;">
                <VBox fx:id="eventsList" spacing="6" style="-fx-padding:8;"/>
            </ScrollPane>
        </Tab>

        <!-- Sub-groups tab -->
        <Tab text="🔗 Sub-Groups">
            <ScrollPane fitToWidth="true" style="-fx-background:white;-fx-background-color:white;">
                <VBox fx:id="subGroupsList" spacing="8" style="-fx-padding:12;"/>
            </ScrollPane>
        </Tab>
    </TabPane>
</VBox>
