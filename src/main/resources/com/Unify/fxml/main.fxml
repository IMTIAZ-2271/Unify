<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.Unify.controller.MainController">

    <BorderPane>
        <left>
            <VBox prefWidth="210" spacing="2" styleClass="sidebar">
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="sidebar-logo">
                    <Label style="-fx-font-size:26;" text="📅"/>
                    <Label style="-fx-text-fill:white;-fx-font-weight:bold;-fx-font-size:15;" text="Unify"/>
                </HBox>
                <HBox fx:id="profileNameAndPictureCell" alignment="CENTER_LEFT" onMouseClicked="#showProfile"
                      spacing="10" styleClass="sidebar-user">
                    <StackPane>
                        <ImageView fx:id="userAvatar" fitHeight="36" fitWidth="36"/>
                    </StackPane>
                    <Label fx:id="userNameLabel" maxWidth="130" style="-fx-text-fill:white;-fx-font-weight:bold;"/>
                </HBox>
                <Separator style="-fx-opacity:0.3;"/>

                <Button maxWidth="Infinity" onAction="#showCalendar" styleClass="sbar-btn" text="📅  Calendar"/>
                <Button maxWidth="Infinity" onAction="#showGroups" styleClass="sbar-btn" text="👥  Groups"/>

                <Button maxWidth="Infinity" onAction="#showChat" styleClass="sbar-btn" text="💬  Chat"/>
                <Button maxWidth="Infinity" onAction="#showAnnouncements" styleClass="sbar-btn" text="📢  Announcements"/>

                <Button maxWidth="Infinity" onAction="#showUtilities" styleClass="sbar-btn" text="🛠  Utilities"/>
                <Button maxWidth="Infinity" onAction="#showProfile" styleClass="sbar-btn" text="👤  Profile"/>
                <StackPane>
                    <Button maxWidth="Infinity" onAction="#showNotifications" styleClass="sbar-btn"
                            text="🔔  Notifications"/>
                    <Label fx:id="notifBadge" style="-fx-translate-x:-8;-fx-translate-y:4;" styleClass="badge"
                           StackPane.alignment="TOP_RIGHT"/>
                </StackPane>
                <Region VBox.vgrow="ALWAYS"/>
                <Separator style="-fx-opacity:0.3;"/>
                <Button maxWidth="Infinity" onAction="#doLogout" styleClass="sbar-btn-danger" text="🚪  Logout"/>
            </VBox>
        </left>
        <center>
            <StackPane fx:id="contentArea" style="-fx-background-color:#F8FAFC;" BorderPane.alignment="CENTER"/>
        </center>
    </BorderPane>

    <StackPane fx:id="overlayArea2" alignment="CENTER" style="-fx-background-color:rgba(0,0,0,0.48);" visible="false"/>
    <StackPane fx:id="overlayArea" style="-fx-background-color:rgba(0,0,0,0.48);" visible="false"/>

</StackPane>