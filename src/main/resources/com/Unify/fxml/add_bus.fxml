<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" style="-fx-padding: 30; -fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.Unify.controller.AddBusController">

    <Label text="Add New Bus" textFill="#2c3e50">
        <font>
            <Font name="System Bold" size="20.0" />
        </font>
    </Label>

    <GridPane hgap="10" vgap="15">
        <Label text="Bus Number:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="busNumberField" promptText="e.g., B-05" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <Label text="Route Name:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextField fx:id="routeField" promptText="e.g., Campus to Mirpur" GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <Label text="Departure Time:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <TextField fx:id="timeField" promptText="HH:MM:SS (e.g., 14:30:00)" GridPane.columnIndex="1" GridPane.rowIndex="2" />

        <Label text="Trip Type:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
        <ComboBox fx:id="typeCombo" prefWidth="150.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />

        <Label text="Message/Status:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
        <TextField fx:id="messageField" promptText="Optional status..." GridPane.columnIndex="1" GridPane.rowIndex="4" />
    </GridPane>

    <HBox spacing="15.0" alignment="CENTER" style="-fx-padding: 10 0 0 0;">
        <Button text="Cancel" onAction="#handleCancel" style="-fx-background-color: #e2e8f0; -fx-text-fill: #0f172a; -fx-padding: 8 20;" />
        <Button text="Save Bus" onAction="#handleSave" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20;" />
    </HBox>

</VBox>