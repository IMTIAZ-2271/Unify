<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" style="-fx-padding: 30; -fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.Unify.controller.AddBusController">

    <Label text="Add New Bus" textFill="#2c3e50">
        <font>
            <Font name="System Bold" size="20.0" />
        </font>
    </Label>

    <GridPane hgap="10" vgap="15">
        <Label text="Bus Number:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
        <TextField fx:id="busNumberField" promptText="e.g., B-05" GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-padding: 8;"/>

        <Label text="Route Name:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
        <TextField fx:id="routeField" promptText="e.g., Campus to Mirpur" GridPane.columnIndex="1" GridPane.rowIndex="1" style="-fx-padding: 8;"/>

        <Label text="Departure Time:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
        <TextField fx:id="timeField" promptText="HH:MM:SS" GridPane.columnIndex="1" GridPane.rowIndex="2" style="-fx-padding: 8;"/>

        <Label text="Trip Type:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
        <ComboBox fx:id="typeCombo" prefWidth="150.0" GridPane.columnIndex="1" GridPane.rowIndex="3" style="-fx-padding: 4;"/>

        <Label text="Message/Status:" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-text-fill: #475569; -fx-font-weight: bold;"/>
        <TextField fx:id="messageField" promptText="Optional status..." GridPane.columnIndex="1" GridPane.rowIndex="4" style="-fx-padding: 8;"/>
    </GridPane>

    <HBox spacing="15.0" alignment="CENTER_RIGHT" style="-fx-padding: 20 0 0 0;">
        <Button text="Cancel" onAction="#handleCancel" style="-fx-background-color: transparent; -fx-text-fill: #64748B; -fx-font-weight: bold; -fx-padding: 6 10; -fx-cursor: hand;" />
        <Button text="Save Bus" onAction="#handleSave" style="-fx-background-color: #3B82F6; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 8 20; -fx-font-weight: bold; -fx-cursor: hand;" />
    </HBox>

</VBox>