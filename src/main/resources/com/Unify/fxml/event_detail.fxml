<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.Unify.controller.EventDetailController"
      styleClass="dialog-panel" spacing="14" prefWidth="480">
    <padding>
        <Insets top="22" right="24" bottom="22" left="24"/>
    </padding>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Circle fx:id="colorDot" radius="9"/>
        <Label fx:id="titleLabel" style="-fx-font-size:20;-fx-font-weight:bold;-fx-text-fill:#1E293B;" wrapText="true"/>
    </HBox>
    <Label fx:id="typeBadge" styleClass="type-badge"/>

    <GridPane hgap="12" vgap="8">
        <Label text="Start:" styleClass="dk" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <Label fx:id="startLabel" styleClass="dv" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <Label text="End:" styleClass="dk" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <Label fx:id="endLabel" styleClass="dv" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <Label text="Location:" styleClass="dk" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <Label fx:id="locationLabel" styleClass="dv" GridPane.columnIndex="1" GridPane.rowIndex="2" wrapText="true"/>
        <Label text="Group:" styleClass="dk" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <Label fx:id="groupLabel" styleClass="dv" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
        <Label text="By:" styleClass="dk" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <Label fx:id="creatorLabel" styleClass="dv" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
        <columnConstraints>
            <ColumnConstraints minWidth="80" maxWidth="80"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>
    </GridPane>

    <Separator/>
    <Label text="Description" styleClass="field-label"/>
    <Label fx:id="descLabel" wrapText="true"
           style="-fx-text-fill:#475569;-fx-padding:8;-fx-background-color:#F8FAFC;-fx-background-radius:6;"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="editBtn" text="Edit" styleClass="btn-primary-sm" onAction="#doEdit"/>
        <Button fx:id="deleteBtn" text="Delete" styleClass="btn-danger-sm" onAction="#doDelete"/>
        <Button text="Close" styleClass="btn-outline-sm" onAction="#doClose"/>
    </HBox>
</VBox>
