<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="640" prefWidth="800" style="-fx-background-color:white;" xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17.0.12" fx:controller="com.Unify.controller.GroupDetailController">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="16"
          style="-fx-padding:20 24;-fx-border-color:#E2E8F0;-fx-border-width:0 0 1 0;-fx-background-color:white;">
        <StackPane>
            <ImageView fx:id="groupAvatar" fitHeight="80" fitWidth="80"/>
        </StackPane>
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label fx:id="groupName" style="-fx-font-size:22;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
            <Label fx:id="groupCode" style="-fx-text-fill:#888;-fx-font-size:11;"/>
            <HBox spacing="12">
                <Label fx:id="memberCount" style="-fx-text-fill:#64748B;-fx-font-size:12;"/>
                <Label fx:id="parentLabel" style="-fx-text-fill:#94A3B8;-fx-font-size:12;"/>
            </HBox>
            <Label fx:id="roleLabel" style="-fx-text-fill:#3B82F6;-fx-font-weight:bold;-fx-font-size:12;"/>
        </VBox>
        <VBox alignment="TOP_RIGHT" spacing="5.0">
            <HBox fx:id="adminBar" spacing="8">
                <Button onAction="#doEditGroup" styleClass="btn-outline-sm" text="✏️ Edit Group"/>
            </HBox>
            <Button fx:id="leaveBtn" onAction="#doLeave" styleClass="btn-danger-sm" text="Leave Group"/>
            <Button fx:id="joinBtn" onAction="#requestJoin" text="Join Group"/>
        </VBox>
    </HBox>
    <Label fx:id="descLabel" style="-fx-padding:8 16;-fx-text-fill:#64748B;" wrapText="true"/>

    <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">

        <!-- Members tab -->
        <Tab text="👥 Members">
            <VBox spacing="0">
                <HBox alignment="CENTER" spacing="8" style="-fx-padding:8 12;">
                    <TextField fx:id="userSearchField" onAction="#doSearchUser" promptText="Search users to invite…"
                               HBox.hgrow="ALWAYS"/>
                    <Button onAction="#doSearchUser" styleClass="btn-primary-sm" text="Search"/>
                </HBox>
                <ScrollPane fitToWidth="true" prefHeight="90"
                            style="-fx-background:#F8FAFC;-fx-background-color:#F8FAFC;">
                    <VBox fx:id="userSearchResults" spacing="2" style="-fx-padding:4;"/>
                </ScrollPane>
                <Separator/>
                <ScrollPane fitToWidth="true" style="-fx-background:white;-fx-background-color:white;"
                            VBox.vgrow="ALWAYS">
                    <VBox fx:id="membersList" spacing="0"/>
                </ScrollPane>
            </VBox>
        </Tab>

        <!-- Group Calendar tab -->
        <Tab text="📅 Calendar">
            <VBox fx:id="groupCalendarContainer" spacing="0" style="-fx-background-color:white;" VBox.vgrow="ALWAYS"/>
        </Tab>

        <!-- Events list tab -->
        <Tab text="📋 Events">
            <ScrollPane fitToWidth="true" style="-fx-background:white;-fx-background-color:white;" VBox.vgrow="ALWAYS">
                <VBox fx:id="eventsList" spacing="6" style="-fx-padding:8;"/>
            </ScrollPane>
        </Tab>

        <!-- Sub-groups tab -->
        <Tab text="🔗 Sub-Groups">
            <ScrollPane fitToWidth="true" style="-fx-background:white;-fx-background-color:white;">
                <VBox fx:id="subGroupsList" spacing="8" style="-fx-padding:12;"/>
            </ScrollPane>
        </Tab>
        <Tab text="📢 Announcements">
            <VBox spacing="10" style="-fx-padding:12; -fx-background-color:white;">
                <VBox fx:id="postAnnouncementBox" spacing="8" style="-fx-padding:10; -fx-background-color:#F8FAFC; -fx-border-color:#E2E8F0; -fx-background-radius:5; -fx-border-radius:5;" managed="false" visible="false">
                    <Label text="Post New Announcement" style="-fx-font-weight:bold;"/>
                    <TextField fx:id="announceTitleField" promptText="Announcement Title..."/>
                    <TextArea fx:id="announceContentField" promptText="What's the news?" prefRowCount="3"/>
                    <Button text="Post Announcement" styleClass="btn-primary-sm" onAction="#postAnnouncement"/>
                </VBox>

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background:white;-fx-background-color:white;">
                    <VBox fx:id="announcementsList" spacing="10"/>
                </ScrollPane>
            </VBox>
        </Tab>

        <Tab text="💬 Group Chat">
            <VBox spacing="0" style="-fx-background-color: white;">

                <ScrollPane fx:id="chatScroll" fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background: white; -fx-background-color: white;">
                    <VBox fx:id="chatList" spacing="10" style="-fx-padding: 15; -fx-background-color: white;"/>
                </ScrollPane>

                <HBox fx:id="replyPreviewBox" visible="false" managed="false" spacing="10" style="-fx-padding: 8 15; -fx-background-color: #F1F5F9; -fx-border-color: #00A884; -fx-border-width: 0 0 0 4;">
                    <VBox HBox.hgrow="ALWAYS">
                        <Label fx:id="replyPreviewName" style="-fx-font-weight:bold; -fx-text-fill:#00A884; -fx-font-size:12;"/>
                        <Label fx:id="replyPreviewText" style="-fx-text-fill:#64748B; -fx-font-size:11;" wrapText="true" maxHeight="30"/>
                    </VBox>
                    <Button text="✕" onAction="#cancelReply" style="-fx-background-color:transparent; -fx-text-fill:#94A3B8; -fx-cursor:hand;"/>
                </HBox>

                <HBox spacing="10" style="-fx-padding: 10 15 10 15; -fx-background-color: #F8FAFC; -fx-alignment: CENTER; -fx-border-color: #E2E8F0; -fx-border-width: 1 0 0 0;">
                    <TextField fx:id="chatInputField" promptText="Type a message..." HBox.hgrow="ALWAYS" onAction="#sendMessage"
                               style="-fx-background-radius: 20; -fx-padding: 10 15; -fx-background-color: white; -fx-border-color: #CBD5E1; -fx-border-radius: 20;"/>
                    <Button text="➤" onAction="#sendMessage" style="-fx-background-radius: 50; -fx-min-width: 45; -fx-min-height: 45; -fx-background-color: #00A884; -fx-text-fill: white; -fx-font-size: 18; -fx-cursor: hand;"/>
                </HBox>

            </VBox>
        </Tab>
    </TabPane>
</VBox>
