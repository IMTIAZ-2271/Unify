<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.cell.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15" style="-fx-background-color: #F8FAFC; -fx-padding: 20;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.Unify.controller.TransportController">

    <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 0 0 10 0; -fx-border-color: #E2E8F0; -fx-border-width: 0 0 1 0;">
        <Button text="⬅ Back" onAction="#goBack" style="-fx-background-color: transparent; -fx-text-fill: #64748B; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 5 10;"/>
        <Label text="Bus Schedules" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Select Group: " style="-fx-font-weight: bold; -fx-text-fill: #64748B;"/>
        <ComboBox fx:id="groupComboBox" prefWidth="200"/>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 5 0;">
        <TextField fx:id="searchField" promptText="🔍 Search route or bus..." prefWidth="250" style="-fx-padding: 8; -fx-background-radius: 5; -fx-border-color: #cbd5e1;"/>
        <Region HBox.hgrow="ALWAYS" />

        <Button fx:id="addBusButton" text="➕ Add New Bus" onAction="#handleAddBus" visible="false" managed="false" style="-fx-background-color: #3B82F6; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 8 15; -fx-font-weight: bold; -fx-cursor: hand;"/>
    </HBox>

    <TableView fx:id="busTable" prefHeight="400.0" prefWidth="800.0" VBox.vgrow="ALWAYS" style="-fx-background-radius: 5; -fx-border-color: #e2e8f0;">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
        <columns>
            <TableColumn fx:id="colBusNumber" text="Bus Number" prefWidth="120">
                <cellValueFactory><PropertyValueFactory property="busNumber" /></cellValueFactory>
            </TableColumn>
            <TableColumn fx:id="colRoute" text="Route" prefWidth="200">
                <cellValueFactory><PropertyValueFactory property="routeName" /></cellValueFactory>
            </TableColumn>
            <TableColumn fx:id="colTime" text="Departure Time" prefWidth="150">
                <cellValueFactory><PropertyValueFactory property="departureTime" /></cellValueFactory>
            </TableColumn>
            <TableColumn fx:id="colType" text="Type" prefWidth="120">
                <cellValueFactory><PropertyValueFactory property="tripType" /></cellValueFactory>
            </TableColumn>
            <TableColumn fx:id="colMessage" text="Message / Status" prefWidth="250">
                <cellValueFactory><PropertyValueFactory property="message" /></cellValueFactory>
            </TableColumn>

            <TableColumn fx:id="colAction" text="Action" prefWidth="140" />
        </columns>
    </TableView>

    <Label style="-fx-background-color: #e0f2fe; -fx-padding: 15; -fx-background-radius: 8; -fx-text-fill: #0369a1; -fx-border-color: #bae6fd; -fx-border-radius: 8;"
           text="The university operates a unified ticketing system. Please purchase your travel tickets at the campus transport counters prior to boarding. A single ticket grants access to any scheduled route."
           textAlignment="CENTER" wrapText="true" maxWidth="Infinity"/>
</VBox>