<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>

<HBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.Unify.controller.ChatController" style="-fx-background-color: white;">

    <VBox prefWidth="280" style="-fx-border-color: #E2E8F0; -fx-border-width: 0 1 0 0; -fx-background-color: #F8FAFC;">
        <VBox spacing="10" style="-fx-padding: 15;">
            <Label text="Chats" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
            <TextField fx:id="searchGroupField" promptText="🔍 Search groups..." style="-fx-background-radius: 15; -fx-padding: 8 12;"/>
        </VBox>
        <ListView fx:id="groupListView" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: transparent;"/>
    </VBox>

    <VBox HBox.hgrow="ALWAYS" fx:id="chatArea" visible="false">

        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 10 20; -fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-width: 0 0 1 0;">
            <StackPane>
                <ImageView fx:id="chatHeaderAvatar" fitHeight="42" fitWidth="42"/>
            </StackPane>
            <VBox HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
                <Label fx:id="chatHeaderName" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                <Label fx:id="chatHeaderSub" style="-fx-text-fill: #64748B; -fx-font-size: 12;"/>
            </VBox>
            <Button fx:id="settingsBtn" text="⋮" style="-fx-background-color: transparent; -fx-font-size: 24; -fx-font-weight: bold; -fx-cursor: hand; -fx-text-fill: #64748B;"/>
        </HBox>

        <ScrollPane fx:id="chatScroll" fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background: #E5E7EB; -fx-background-color: #E5E7EB;">
            <VBox fx:id="chatList" spacing="10" style="-fx-padding: 15; -fx-background-color: #E5E7EB;"/>
        </ScrollPane>

        <HBox fx:id="replyPreviewBox" visible="false" managed="false" spacing="10" style="-fx-padding: 8 15; -fx-background-color: #F1F5F9; -fx-border-color: #00A884; -fx-border-width: 0 0 0 4;">
            <VBox HBox.hgrow="ALWAYS">
                <Label fx:id="replyPreviewName" style="-fx-font-weight:bold; -fx-text-fill:#00A884; -fx-font-size:12;"/>
                <Label fx:id="replyPreviewText" style="-fx-text-fill:#64748B; -fx-font-size:11;" wrapText="true" maxHeight="30"/>
            </VBox>
            <Button text="✕" onAction="#cancelReply" style="-fx-background-color:transparent; -fx-text-fill:#94A3B8; -fx-cursor:hand;"/>
        </HBox>

        <HBox spacing="10" style="-fx-padding: 10 15; -fx-background-color: #F8FAFC; -fx-alignment: CENTER;">

            <TextField fx:id="chatInputField" promptText="Type a message..." HBox.hgrow="ALWAYS" onAction="#sendMessage"
                       style="-fx-background-radius: 20; -fx-padding: 10 15; -fx-background-color: white; -fx-border-color: #CBD5E1; -fx-border-radius: 20;"/>

            <Button fx:id="sendBtn" text="➤" onAction="#sendMessage" style="-fx-background-radius: 50; -fx-min-width: 45; -fx-min-height: 45; -fx-background-color: #00A884; -fx-text-fill: white; -fx-font-size: 18; -fx-cursor: hand;"/>
        </HBox>
    </VBox>

    <VBox fx:id="placeholderArea" HBox.hgrow="ALWAYS" alignment="CENTER" style="-fx-background-color: #F8FAFC;">
        <Label text="Select a group to start chatting" style="-fx-font-size: 18; -fx-text-fill: #94A3B8;"/>
    </VBox>

</HBox>