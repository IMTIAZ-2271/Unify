<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="620.0" minWidth="900.0"
      prefHeight="620" prefWidth="900" styleClass="login-root" xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.Unify.controller.RegisterController">

    <VBox alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity"
          minWidth="-Infinity" prefHeight="620.0" prefWidth="400.0" spacing="12" styleClass="brand-panel">
        <Label style="-fx-font-size:64;" text="📅"/>
        <Label style="-fx-font-size:30;-fx-font-weight:bold;-fx-text-fill:white;" text="CalendarApp"/>
        <Label style="-fx-font-size:14;-fx-text-fill:rgba(255,255,255,0.8);-fx-text-alignment:center;"
               text="Join and start organizing your life." wrapText="true"/>
    </VBox>

    <ScrollPane fitToWidth="true" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                minHeight="-Infinity" minWidth="-Infinity" prefHeight="620.0" prefWidth="500.0"
                style="-fx-background:white;-fx-background-color:white;" HBox.hgrow="ALWAYS">
        <VBox alignment="CENTER" spacing="0" styleClass="form-panel">
            <VBox maxWidth="360" spacing="14">
                <Label style="-fx-font-size:24;-fx-font-weight:bold;-fx-text-fill:#1E293B;" text="Create Account"/>

                <VBox spacing="5">
                    <Label styleClass="field-label" text="Username *"/>
                    <TextField fx:id="usernameField" promptText="3-50 chars, letters/numbers/_" styleClass="input"/>
                </VBox>
                <VBox spacing="5">
                    <Label styleClass="field-label" text="Email *"/>
                    <TextField fx:id="emailField" promptText="you@example.com" styleClass="input"/>
                </VBox>
                <VBox spacing="5">
                    <Label styleClass="field-label" text="Display Name"/>
                    <TextField fx:id="displayNameField" promptText="Your full name (optional)" styleClass="input"/>
                </VBox>
                <VBox spacing="5">
                    <Label styleClass="field-label" text="Password *"/>
                    <PasswordField fx:id="passwordField" promptText="min 6 characters" styleClass="input"/>
                </VBox>
                <VBox spacing="5">
                    <Label styleClass="field-label" text="Confirm Password *"/>
                    <PasswordField fx:id="confirmField" promptText="repeat password" styleClass="input"/>
                </VBox>

                <Label fx:id="errorLabel" maxWidth="360" styleClass="err" wrapText="true"/>

                <Button fx:id="registerBtn" maxWidth="Infinity" onAction="#doRegister" prefHeight="42"
                        styleClass="btn-primary" text="Create Account"/>

                <HBox alignment="CENTER" spacing="8">
                    <Label style="-fx-text-fill:#888;" text="Have an account?"/>
                    <Button onAction="#goLogin" styleClass="btn-link" text="Sign In"/>
                </HBox>
            </VBox>
        </VBox>
    </ScrollPane>
</HBox>
