<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" style="-fx-padding: 20; -fx-background-color: #F8FAFC;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.Unify.controller.AdminDashboardController">

    <Label text="User Management Dashboard" textFill="#2c3e50">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <Label text="Right-click a user to promote or demote them." textFill="#64748b"/>

    <TableView fx:id="userTable" prefHeight="500.0" prefWidth="700.0" VBox.vgrow="ALWAYS">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
        <columns>
            <TableColumn fx:id="colId" prefWidth="50.0" text="ID">
                <cellValueFactory><PropertyValueFactory property="id" /></cellValueFactory>
            </TableColumn>
            <TableColumn fx:id="colUsername" prefWidth="150.0" text="Username">
                <cellValueFactory><PropertyValueFactory property="username" /></cellValueFactory>
            </TableColumn>
            <TableColumn fx:id="colEmail" prefWidth="250.0" text="Email">
                <cellValueFactory><PropertyValueFactory property="email" /></cellValueFactory>
            </TableColumn>
            <TableColumn fx:id="colAdmin" prefWidth="100.0" text="Is Admin?">
                <cellValueFactory><PropertyValueFactory property="admin" /></cellValueFactory>
            </TableColumn>
        </columns>
    </TableView>

</VBox>