<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" style="-fx-padding: 20; -fx-background-color: #F8FAFC;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.Unify.controller.TransportController">

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Button text="⬅ Back" onAction="#goBack" styleClass="btn-outline-small"/>

        <Label text="Bus Schedules" textFill="#2c3e50">
            <font><Font name="System Bold" size="24.0" /></font>
        </Label>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Select Group: " style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="groupComboBox" prefWidth="200"/>
    </HBox>
    <HBox spacing="15.0" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="🔍 Search route or bus number..." prefWidth="300.0" style="-fx-padding: 8; -fx-background-radius: 5; -fx-border-color: #cbd5e1; -fx-border-radius: 5;"/>
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="addBusButton" text="➕ Add New Bus" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 15;" visible="false" managed="false" onAction="#handleAddBus"/>
    </HBox>

    <TableView fx:id="busTable" prefHeight="400.0" prefWidth="800.0" VBox.vgrow="ALWAYS">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
        <columns>
            <TableColumn fx:id="colBusNumber" text="Bus Number">
                <cellValueFactory><PropertyValueFactory property="busNumber" /></cellValueFactory>
            </TableColumn>
            <TableColumn fx:id="colRoute" text="Route">
                <cellValueFactory><PropertyValueFactory property="routeName" /></cellValueFactory>
            </TableColumn>
            <TableColumn fx:id="colTime" text="Departure Time">
                <cellValueFactory><PropertyValueFactory property="departureTime" /></cellValueFactory>
            </TableColumn>
            <TableColumn fx:id="colType" text="Type">
                <cellValueFactory><PropertyValueFactory property="tripType" /></cellValueFactory>
            </TableColumn>
            <TableColumn fx:id="colMessage" text="Message / Status">
                <cellValueFactory><PropertyValueFactory property="message" /></cellValueFactory>
            </TableColumn>
        </columns>
    </TableView>

    <Label style="-fx-background-color: #e0f2fe; -fx-padding: 15; -fx-background-radius: 8; -fx-text-fill: #0369a1; -fx-border-color: #bae6fd; -fx-border-radius: 8;"
           text="The university operates a unified ticketing system. Please purchase your travel tickets at the campus transport counters prior to boarding. A single ticket grants access to any scheduled route."
           textAlignment="CENTER" wrapText="true" maxWidth="Infinity"/>

</VBox>