<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="30" style="-fx-padding: 40;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.Unify.controller.UtilityController">

    <Label text="Select a Utility" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <HBox alignment="CENTER" spacing="20">
        <VBox alignment="CENTER" spacing="10" style="-fx-background-color: #ffffff; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" onMouseClicked="#openLibraryMenu" prefWidth="200" prefHeight="150" styleClass="utility-card">
            <Label text="📚" style="-fx-font-size: 40px;"/>
            <Label text="Library" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        </VBox>

        <VBox alignment="CENTER" spacing="10" style="-fx-background-color: #ffffff; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);"
              onMouseClicked="#openCanteenMenu" prefWidth="200" prefHeight="150" styleClass="utility-card">
            <Label text="🍔" style="-fx-font-size: 40px;"/>
            <Label text="Canteen" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        </VBox>

        <VBox alignment="CENTER" spacing="10" style="-fx-background-color: #ffffff; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);"
              onMouseClicked="#openTransportMenu" prefWidth="200" prefHeight="150" styleClass="utility-card">
            <Label text="🚌" style="-fx-font-size: 40px;"/>
            <Label text="Transportation" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        </VBox>
    </HBox>

</VBox>