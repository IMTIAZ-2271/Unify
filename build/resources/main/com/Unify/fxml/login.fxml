<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="620.0" minWidth="900.0"
      prefHeight="620" prefWidth="900" styleClass="login-root" xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.Unify.controller.LoginController">

    <VBox alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity"
          minWidth="-Infinity" prefHeight="620.0" prefWidth="400" spacing="12" styleClass="brand-panel">
        <Label style="-fx-font-size:64;" text="📅"/>
        <Label style="-fx-font-size:30;-fx-font-weight:bold;-fx-text-fill:white;" text="Unify"/>
        <Label style="-fx-font-size:14;-fx-text-fill:rgba(250,248,248,0.96);-fx-text-alignment:center;"
               text="Manage your time, connect your world." wrapText="true"/>
    </VBox>

    <VBox alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity"
          minWidth="-Infinity" prefHeight="620.0" prefWidth="500.0" spacing="0" styleClass="form-panel"
          HBox.hgrow="ALWAYS">
        <VBox maxWidth="340" spacing="18">
            <Label style="-fx-font-size:26;-fx-font-weight:bold;-fx-text-fill:#1E293B;" text="Welcome back"/>
            <Label style="-fx-text-fill:#100909;" text="Sign in to your account"/>

            <VBox spacing="6">
                <Label styleClass="field-label" text="Username or Email"/>
                <TextField fx:id="usernameField" promptText="username or email" styleClass="input"/>
            </VBox>
            <VBox spacing="6">
                <Label styleClass="field-label" text="Password"/>
                <PasswordField fx:id="passwordField" promptText="password" styleClass="input"/>
            </VBox>

            <Label fx:id="errorLabel" maxWidth="340" styleClass="err" wrapText="true"/>

            <Button fx:id="loginBtn" maxWidth="Infinity" onAction="#doLogin" prefHeight="42" styleClass="btn-primary"
                    text="Sign In"/>

            <HBox alignment="CENTER" spacing="8">
                <Label style="-fx-text-fill:#100f0f;" text="New here?"/>
                <Button onAction="#goRegister" styleClass="btn-link" text="Create an account"/>
            </HBox>
        </VBox>
    </VBox>
</HBox>
